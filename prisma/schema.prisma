generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  QUEUED
  CALLING
  BOOKED
  NOT_INTERESTED
  LINK_EMAILED
  CALLBACK_REQUESTED
  NO_ANSWER
  WRONG_NUMBER
  DO_NOT_CALL
}

enum CampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

model Lead {
  id             String   @id @default(cuid())
  name           String
  phone          String   @unique
  company        String?
  industry       String?
  openerHook     String?  @map("opener_hook")
  status         LeadStatus @default(QUEUED)
  retellCallId   String?  @unique @map("retell_call_id")
  timezone       String?
  campaignId     String?  @map("campaign_id")
  campaign       Campaign? @relation(fields: [campaignId], references: [id])
  callAttempts   CallAttempt[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("leads")
}

model CallAttempt {
  id                  String   @id @default(cuid())
  leadId              String   @map("lead_id")
  lead                Lead     @relation(fields: [leadId], references: [id])
  retellCallId        String   @unique @map("retell_call_id")
  outcome             LeadStatus?
  transcript          String?  @db.Text
  summary             String?  @db.Text
  recordingUrl        String?  @map("recording_url")
  durationSeconds     Int?     @map("duration_seconds")
  disconnectionReason String?  @map("disconnection_reason")
  rawPayload          Json?    @map("raw_payload")
  startedAt           DateTime? @map("started_at")
  endedAt             DateTime? @map("ended_at")

  // New: post-call analysis fields from Retell
  mainPainPoint       String?  @map("main_pain_point") @db.Text
  prospectEmail       String?  @map("prospect_email")
  preferredTimes      String?  @map("preferred_times")
  bookedDate          String?  @map("booked_date")
  bookedDay           String?  @map("booked_day")
  bookedTime          String?  @map("booked_time")
  teamSize            String?  @map("team_size")

  createdAt           DateTime @default(now()) @map("created_at")

  @@map("call_attempts")
}

model Campaign {
  id            String   @id @default(cuid())
  name          String
  status        CampaignStatus @default(DRAFT)
  currentLeadId String?  @map("current_lead_id")
  leads         Lead[]
  gapSeconds    Int      @default(30) @map("gap_seconds")
  callStartHour Int      @default(9) @map("call_start_hour")
  callEndHour   Int      @default(18) @map("call_end_hour")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("campaigns")
}

model Settings {
  id                    String   @id @default(cuid())

  // Retell
  retellApiKey          String?  @map("retell_api_key")
  retellAgentId         String?  @map("retell_agent_id")
  retellFromNumber      String?  @map("retell_from_number")

  // Gemini (call summaries)
  geminiApiKey          String?  @map("gemini_api_key")

  // Resend (booking link emails)
  resendApiKey          String?  @map("resend_api_key")
  bookingUrl            String?  @map("booking_url")

  // Apollo
  apolloApiKey          String?  @map("apollo_api_key")

  // Proxycurl
  proxycurlApiKey       String?  @map("proxycurl_api_key")

  // OpenAI
  openaiApiKey          String?  @map("openai_api_key")
  openaiModel           String?  @default("gpt-4o-mini") @map("openai_model")

  // Twilio
  twilioAccountSid      String?  @map("twilio_account_sid")
  twilioAuthToken       String?  @map("twilio_auth_token")
  twilioFromNumber      String?  @map("twilio_from_number")

  // Calendly
  calendlyAccessToken   String?  @map("calendly_access_token")
  calendlyEventTypeUri  String?  @map("calendly_event_type_uri")

  // Gmail
  gmailConnected        Boolean  @default(false) @map("gmail_connected")
  gmailRefreshToken     String?  @map("gmail_refresh_token")
  gmailEmailAddress     String?  @map("gmail_email_address")

  // Calling rules
  callStartHour         Int      @default(9) @map("call_start_hour")
  callEndHour            Int      @default(18) @map("call_end_hour")
  callsPerHourLimit     Int      @default(10) @map("calls_per_hour_limit")
  callGapSeconds        Int      @default(30) @map("call_gap_seconds")
  maxRetryAttempts      Int      @default(3) @map("max_retry_attempts")
  voicemailOnAttempt    Int      @default(2) @map("voicemail_on_attempt")

  // Email rules
  maxEmailsPerDay       Int      @default(100) @map("max_emails_per_day")
  emailSendStartHour    Int      @default(9) @map("email_send_start_hour")
  emailSendEndHour      Int      @default(18) @map("email_send_end_hour")
  emailGapSeconds       Int      @default(10) @map("email_gap_seconds")

  // Google Sheets
  googleServiceAccountKeyPath String? @map("google_service_account_key_path")
  connectedSheetUrl     String?  @map("connected_sheet_url")
  connectedSheetName    String?  @map("connected_sheet_name")

  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("settings")
}