generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  NEW
  QUEUED
  CALLING
  BOOKED
  NOT_INTERESTED
  LINK_EMAILED
  CALLBACK_REQUESTED
  NO_ANSWER
  WRONG_NUMBER
  DO_NOT_CALL
}

enum LeadSource {
  MANUAL
  CSV
  SHEETS
  HOMEPAGE
  APOLLO
}

enum EnrichmentStatus {
  PENDING
  ENRICHING
  READY
  FAILED
}

enum CampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

model Lead {
  id             String   @id @default(cuid())
  name           String
  phone          String   @unique
  email          String?
  company        String?
  industry       String?
  openerHook     String?  @map("opener_hook")
  status         LeadStatus @default(QUEUED)
  source         LeadSource @default(MANUAL)
  retellCallId   String?  @unique @map("retell_call_id")
  timezone       String?
  finalScore          Float?   @map("final_score")
  structuredScore      Float?   @map("structured_score")
  naturalLanguageScore Float?   @map("natural_language_score")
  scoreBreakdown       Json?    @map("score_breakdown")
  scoredAt            DateTime? @map("scored_at")
  notes         String?  @db.Text
  isSuppressed  Boolean  @default(false) @map("is_suppressed")
  callbackAt    DateTime? @map("callback_at")
  retryCount    Int      @default(0) @map("retry_count")
  retryAt       DateTime? @map("retry_at")
  emailSubject       String?   @db.Text @map("email_subject")
  emailBody          String?   @db.Text @map("email_body")
  emailGeneratedAt   DateTime? @map("email_generated_at")
  emailSentAt        DateTime? @map("email_sent_at")
  briefOpenerHook       String?  @db.Text @map("brief_opener_hook")
  briefPainAssumption   String?  @db.Text @map("brief_pain_assumption")
  briefProofPoint       String?  @db.Text @map("brief_proof_point")
  briefPersonalizedPitch String? @db.Text @map("brief_personalized_pitch")
  briefGeneratedAt      DateTime? @map("brief_generated_at")


  // Apollo import fields
  apolloId       String?  @unique @map("apollo_id")
  employeeCount  Int?     @map("employee_count")
  location       String?
  jobTitle       String?  @map("job_title")
  seniorityLevel String?  @map("seniority_level")
  enrichmentStatus EnrichmentStatus @default(PENDING) @map("enrichment_status")

  campaignId     String?  @map("campaign_id")
  campaign       Campaign? @relation(fields: [campaignId], references: [id])
  icpProfileId   String?  @map("icp_profile_id")
  icpProfile     ICPProfile? @relation(fields: [icpProfileId], references: [id])
  callAttempts   CallAttempt[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  website              String?  // company domain, pulled from Apollo's organization.website_url if available

  // Enrichment results
  websiteSummary       Json?    @map("website_summary")
  techStackDetected     String[] @map("tech_stack_detected")
  newsSummary          Json?    @map("news_summary")
  enrichedAt           DateTime? @map("enriched_at")

  // Reserved for future LinkedIn enrichment — NOT populated by any code yet.
  // Left in the schema so a future vendor integration doesn't need another
  // migration, but these will be null on every lead until that's built.
  linkedinProfile      Json?    @map("linkedin_profile")
  recentPosts          Json?    @map("recent_posts")
  companyLinkedin       Json?    @map("company_linkedin")

  @@map("leads")
}

model CallAttempt {
  id                  String   @id @default(cuid())
  leadId              String   @map("lead_id")
  lead                Lead     @relation(fields: [leadId], references: [id])
  retellCallId        String   @unique @map("retell_call_id")
  outcome             LeadStatus?
  transcript          String?  @db.Text
  summary             String?  @db.Text
  recordingUrl        String?  @map("recording_url")
  durationSeconds     Int?     @map("duration_seconds")
  disconnectionReason String?  @map("disconnection_reason")
  rawPayload          Json?    @map("raw_payload")
  startedAt           DateTime? @map("started_at")
  endedAt             DateTime? @map("ended_at")

  // New: post-call analysis fields from Retell
  mainPainPoint       String?  @map("main_pain_point") @db.Text
  prospectEmail       String?  @map("prospect_email")
  preferredTimes      String?  @map("preferred_times")
  bookedDate          String?  @map("booked_date")
  bookedDay           String?  @map("booked_day")
  bookedTime          String?  @map("booked_time")
  teamSize            String?  @map("team_size")

  createdAt           DateTime @default(now()) @map("created_at")

  @@map("call_attempts")
}

model Campaign {
  id            String   @id @default(cuid())
  name          String
  status        CampaignStatus @default(DRAFT)
  currentLeadId String?  @map("current_lead_id")
  leads         Lead[]
  gapSeconds    Int      @default(30) @map("gap_seconds")
  callStartHour Int      @default(9) @map("call_start_hour")
  callEndHour   Int      @default(18) @map("call_end_hour")
  emailBeforeCall Boolean @default(false) @map("email_before_call")
  emailWaitHours  Int     @default(48) @map("email_wait_hours")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("campaigns")
}

model Settings {
  id                    String   @id @default(cuid())

  // Retell
  retellApiKey          String?  @map("retell_api_key")
  retellAgentId         String?  @map("retell_agent_id")
  retellFromNumber      String?  @map("retell_from_number")

  // Gemini (call summaries)
  geminiApiKey          String?  @map("gemini_api_key")

  // Resend (booking link emails)
  resendApiKey          String?  @map("resend_api_key")
  bookingUrl            String?  @map("booking_url")

  // Apollo
  apolloApiKey          String?  @map("apollo_api_key")

  // Proxycurl
  proxycurlApiKey       String?  @map("proxycurl_api_key")

  // OpenAI
  openaiApiKey          String?  @map("openai_api_key")
  openaiModel           String?  @default("gpt-4o-mini") @map("openai_model")

  // Twilio
  twilioAccountSid      String?  @map("twilio_account_sid")
  twilioAuthToken       String?  @map("twilio_auth_token")
  twilioFromNumber      String?  @map("twilio_from_number")

  // Cal
  calcomApiKey     String?  @map("calcom_api_key")
  calcomEventTypeId Int?    @map("calcom_event_type_id")
  calcomWebhookSecret String? @map("calcom_webhook_secret")

  // Gmail
  gmailClientId         String?  @map("gmail_client_id")
  gmailClientSecret     String?  @map("gmail_client_secret")
  gmailConnected        Boolean  @default(false) @map("gmail_connected")
  gmailRefreshToken     String?  @map("gmail_refresh_token")
  gmailEmailAddress     String?  @map("gmail_email_address")

  // Calling rules
  callStartHour         Int      @default(9) @map("call_start_hour")
  callEndHour            Int      @default(18) @map("call_end_hour")
  callsPerHourLimit     Int      @default(10) @map("calls_per_hour_limit")
  callGapSeconds        Int      @default(30) @map("call_gap_seconds")
  maxRetryAttempts      Int      @default(3) @map("max_retry_attempts")
  voicemailOnAttempt    Int      @default(2) @map("voicemail_on_attempt")

  // Email rules
  maxEmailsPerDay       Int      @default(100) @map("max_emails_per_day")
  emailSendStartHour    Int      @default(9) @map("email_send_start_hour")
  emailSendEndHour      Int      @default(18) @map("email_send_end_hour")
  emailGapSeconds       Int      @default(10) @map("email_gap_seconds")

  // Google Sheets
  googleServiceAccountKeyPath String? @map("google_service_account_key_path")
  connectedSheetUrl     String?  @map("connected_sheet_url")
  connectedSheetName    String?  @map("connected_sheet_name")

  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
// One profile can be marked active at a time (enforced in app logic — the
// activate endpoint flips every other profile's isActive to false).
model ICPProfile {
  id       String  @id @default(cuid())
  name     String
  isActive Boolean @default(false) @map("is_active")

  // Structured filters
  targetIndustries     String[] @map("target_industries")
  employeeCountMin     Int?     @map("employee_count_min")
  employeeCountMax     Int?     @map("employee_count_max")
  geographyCountry     String?  @map("geography_country")
  geographyRegion      String?  @map("geography_region")
  targetJobTitles      String[] @map("target_job_titles")
  excludeJobTitles     String[] @map("exclude_job_titles")
  positiveSignals      String[] @map("positive_signals")
  negativeSignals      String[] @map("negative_signals")
  linkedinPostKeywords String[] @map("linkedin_post_keywords")
  websiteKeywords      String[] @map("website_keywords")
  minScoreThreshold    Float    @default(7) @map("min_score_threshold")
  competitorTools      String[] @map("competitor_tools")

  // Natural language fields
  idealCustomerDescription     String? @db.Text @map("ideal_customer_description")
  linkedinPresenceDescription  String? @db.Text @map("linkedin_presence_description")
  badFitDescription            String? @db.Text @map("bad_fit_description")
  immediateCallTrigger         String? @db.Text @map("immediate_call_trigger")

  leads Lead[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("icp_profiles")
}

// Global reusable proof-point library — not scoped to a single ICP profile.
// AI picks the most relevant one per lead when generating briefs/emails.
model ProofPoint {
  id          String @id @default(cuid())
  name        String
  metric      String
  description String @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("proof_points")
}

// Global services library, used by AI to pick the right pitch per lead.
model Service {
  id          String @id @default(cuid())
  name        String
  description String @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("services")
}
